# ── Banco de Dados ────────────────────────────────────────────────────────────
POSTGRES_DB=portal_serasa
POSTGRES_USER=serasa
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE

# ── Backend ───────────────────────────────────────────────────────────────────
# Chave JWT — gere com: openssl rand -base64 64
JWT_SECRET=TROQUE_POR_CHAVE_ALEATORIA_64_CHARS
# Origens permitidas no CORS do backend, separadas por vírgula
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://IP_DO_SERVIDOR:3001
# E-mails autorizados a listar e apagar usuários no painel
APP_USER_MANAGEMENT_ALLOWED_EMAILS=gerente@empresa.com,diretor@empresa.com

# ── Serasa Experian ───────────────────────────────────────────────────────────
SERASA_API_URL=https://api.serasaexperian.com.br
SERASA_API_USER=
SERASA_API_PASSWORD=
# Custo por consulta em R$ (padrão 6.33)
SERASA_COST_PER_QUERY=6.33

# ── CNPJ Já ───────────────────────────────────────────────────────────────────
CNPJA_API_KEY=SUA_CHAVE_CNPJA

# ── Gemini AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=SUA_CHAVE_GEMINI
GEMINI_MODEL=gemini-2.5-flash-lite

# ── E-mail (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=cloud29.mailgrid.net.br
SMTP_PORT=587
SMTP_USERNAME=jgmempresarial@jgmempresarial.com
SMTP_PASSWORD=TROQUE_POR_SENHA_DO_EMAIL
EMAIL_FROM=fomento@jgmfomento.com
EMAIL_COMERCIAL=cadastro@jgmfomento.com,elcio.simoes@jgmempresarial.com,jonas.micheline@jgmempresarial.com,walter.marques@jgmempresarial.com
# Desabilite em dev/testes: false
EMAIL_CEDENTE_ENABLED=true

# ── Frontend ──────────────────────────────────────────────────────────────────
# IP ou hostname do servidor — o browser precisa alcançar esta URL
# Exemplo: http://192.168.1.100:8081/api/v1
NEXT_PUBLIC_API_URL=http://IP_DO_SERVIDOR:8081/api/v1

APP_USER_MANAGEMENT_ALLOWED_EMAILS=gerente@empresa.com,walter@admin.com
